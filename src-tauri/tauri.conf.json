{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Codex Island",
  "version": "0.1.1",
  "identifier": "im.codex.island",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "island",
        "title": "Codex Island",
        "width": 360,
        "height": 72,
        "resizable": false,
        "fullscreen": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "visible": true,
        "skipTaskbar": true,
        "shadow": false,
        "acceptFirstMouse": true,
        "focus": false,
        "visibleOnAllWorkspaces": true,
        "titleBarStyle": "Overlay"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "icon": []
  }
}
